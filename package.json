{
  "name": "gw2helper",
  "version": "0.9.150",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "npm run check:yaml && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:yaml": "node scripts/check-yaml.cjs",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:unit": "vitest run",
    "test:unit:full": "vitest run --reporter=tree",
    "test:unit:coverage-guard": "vitest run src/lib/components/all-components.test.ts --reporter=verbose",
    "test": "npm run test:unit && npm run test:e2e",
    "test:e2e": "playwright install && playwright test"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@eslint/js": "^10.0.1",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/eslint": "^8.56.12",
    "@types/howler": "^2.2.12",
    "@types/node": "^22",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/browser-playwright": "^4.1.3",
    "@zerodevx/svelte-toast": "^0.9.6",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "sass": "^1.99.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "svelte-dnd-action": "^0.9.69",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@sveltekit-i18n/parser-icu": "^1.0.8",
    "howler": "^2.2.4",
    "idb-keyval": "^6.2.2",
    "sveltekit-i18n": "^2.4.2"
  },
  "overrides": {
    "vite": "$vite"
  }
}
